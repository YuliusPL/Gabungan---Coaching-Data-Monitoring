<div id="v-pipe">
  <div class="section-hero pipe-hero">
    <div>
      <span class="section-chip pipe-chip">Pipeline Control</span>
      <h2>Funnel dan kualitas pipeline</h2>
      <p>Pantau aging, approval, product mix, dan performa sales dalam satu halaman.</p>
    </div>
  </div>

  <div class="card-mewah filter-card shadow-sm">
    <div class="filter-grid">
      <div>
        <label class="form-label-lite">Tanggal Mulai</label>
        <input type="date" id="p-start" class="form-control form-control-sm" onchange="filterPipe()">
      </div>
      <div>
        <label class="form-label-lite">Tanggal Akhir</label>
        <input type="date" id="p-end" class="form-control form-control-sm" onchange="filterPipe()">
      </div>
      <div>
        <label class="form-label-lite">Cabang</label>
        <select id="p-c" class="form-select form-select-sm" onchange="syncSalesByBranch()"></select>
      </div>
      <div>
        <label class="form-label-lite">Sales</label>
        <select id="p-s" class="form-select form-select-sm" onchange="filterPipe()"></select>
      </div>
    </div>
  </div>

  <div class="kpi-grid">
    <div class="card-mewah metric-card">
      <span class="metric-label">Approval Rate</span>
      <b class="metric-value pipe-text" id="k-conv">0%</b>
      <small>Dari total APK masuk</small>
    </div>

    <div class="card-mewah metric-card">
      <span class="metric-label">Avg Ticket Size</span>
      <b class="metric-value" id="k-avg">Rp 0</b>
      <small>Rata-rata plafond</small>
    </div>

    <div class="card-mewah metric-card metric-wide pipe-total-card">
      <span class="metric-label text-white-50">Estimasi Plafond Pipeline</span>
      <b class="metric-value text-white" id="k-pla">Rp 0</b>
      <small class="text-white-50">Akumulasi data terfilter</small>
    </div>
  </div>

  <div class="desktop-grid two-col">
    <div>
      <h6 class="section-title">Funnel Pipeline</h6>
      <div class="card-mewah funnel-card">
        <div class="funnel-box st-apk">
          <span>APK Masuk</span>
          <span class="funnel-metric"><b id="fn-naik">0</b><small id="fn-naik-p">0%</small></span>
        </div>
        <div class="funnel-box st-app">
          <span>Approve</span>
          <span class="funnel-metric"><b id="fn-app">0</b><small id="fn-app-p">0%</small></span>
        </div>
        <div class="funnel-box st-pen">
          <span>Pending</span>
          <span class="funnel-metric"><b id="fn-pen">0</b><small id="fn-pen-p">0%</small></span>
        </div>
        <div class="funnel-box st-rej">
          <span>Reject</span>
          <span class="funnel-metric"><b id="fn-rej">0</b><small id="fn-rej-p">0%</small></span>
        </div>
        <div class="funnel-box st-cair">
          <span>Cair</span>
          <span class="funnel-metric"><b id="fn-cair">0</b><small id="fn-cair-p">0%</small></span>
        </div>
      </div>
    </div>

    <div>
      <h6 class="section-title">Product Mix</h6>
      <div class="card-mewah chart-card">
        <canvas id="pChartMix"></canvas>
      </div>
    </div>
  </div>

  <div class="desktop-grid three-col">
    <div>
      <h6 class="section-title">Aging Pipeline</h6>
      <div class="card-mewah p-0 overflow-hidden">
        <div class="rank-row"><span>0-3 Hari</span><b id="ag-1">0</b></div>
        <div class="rank-row"><span>4-7 Hari</span><b id="ag-2" class="text-warning">0</b></div>
        <div class="rank-row"><span>8-14 Hari</span><b id="ag-3" class="text-danger">0</b></div>
        <div class="rank-row border-0"><span>&gt; 14 Hari</span><b id="ag-4" class="text-danger fw-bold">0</b></div>
      </div>
    </div>

    <div>
      <h6 class="section-title">Top 10 Sales</h6>
      <div class="card-mewah p-0 overflow-hidden list-card" id="top-sales-list"></div>
    </div>

    <div>
      <h6 class="section-title text-danger">Bottom 10 Sales</h6>
      <div class="card-mewah p-0 overflow-hidden list-card" id="bot-sales-list"></div>
    </div>
  </div>

  <div class="card-mewah p-0 overflow-hidden shadow-sm">
    <div class="table-toolbar">
      <div>
        <b>Detail Data Pipeline</b>
        <small>Debitur, sales, status, keputusan, dan plafond</small>
      </div>
      <input
        type="text"
        id="p-search"
        class="form-control form-control-sm"
        placeholder="Cari debitur / sales / status"
        onkeyup="debounceSearch()"
      >
    </div>

    <div class="table-scroll">
      <table class="table table-sm table-hover mb-0 sticky-table-head data-table">
        <thead>
          <tr>
            <th>DEBITUR</th>
            <th>SALES</th>
            <th>STATUS</th>
            <th>KEPUTUSAN</th>
            <th>PLAFOND</th>
          </tr>
        </thead>
        <tbody id="pipe-body"></tbody>
      </table>
    </div>

    <div class="table-footer">
      <div id="p-info">0 Data Terfilter</div>
    </div>
  </div>
</div>
